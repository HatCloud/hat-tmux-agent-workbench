# Selected language for msg(); resolved below from --lang / $LANG / en.
LANG_SEL=en

msg() {
  # Indirect lookup MSG_<lang>_<key>; fall back to English, then the raw key,
  # so a missing translation degrades gracefully instead of crashing under set -u.
  local v="MSG_${LANG_SEL}_$1" out
  out="${!v:-}"
  if [ -z "$out" ]; then
    v="MSG_en_$1"
    out="${!v:-$1}"
  fi
  printf '%s' "$out"
}

# ---------------------------------------------------------------------------
# Output helpers.
#   say()  — human prose. ALWAYS to STDERR (keeps stdout pure JSONL in --json).
#   jstr() — JSON-encode a bash string via jq.
#   emit() — one JSONL step object on STDOUT (only in --json mode).
# ---------------------------------------------------------------------------
say() {
  printf '%s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

jstr() {
  printf '%s' "$1" | jq -Rs .
}

emit() {
  # emit <step> <status: ok|skip|fail|degraded> <detail-json>
  [ "$JSON_MODE" -eq 1 ] || return 0
  printf '{"step":%s,"status":%s,"detail":%s}\n' \
    "$(jstr "$1")" "$(jstr "$2")" "$3"
}

emit_decision() {
  # emit_decision <step> <resolved-value>
  local step="$1" value="$2" status
  case "$value" in
    skip) status=skip ;;
    *) status=ok ;;
  esac
  emit "$step" "$status" "$(jq -cn --arg v "$value" '{value:$v}')"
}

emit_result() {
  [ "$JSON_MODE" -eq 1 ] || return 0
  printf '{"result":%s}\n' "$(jstr "$RUN_STATUS")"
}

# ---------------------------------------------------------------------------
# Config location + cross-process write lock.
#
# The Go tracker (cmd/agent) writes ~/.config/agent-tracker/agent-config.json
# under a mkdir lock at "<config-dir>/.config.lock.d" with a 5s stale timeout.
# This bash writer MUST use the IDENTICAL lock dir + semantics so Go and the
# wizard never clobber each other. Paths are overridable by env for tests.
# ---------------------------------------------------------------------------
SCRIPT_SELF="${BASH_SOURCE[0]:-$0}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SELF")" && pwd)"
SCRIPT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

CONFIG_LOCK_STALE=5

config_path() {
  printf '%s' "${HAT_AGENT_CONFIG:-$HOME/.config/agent-tracker/agent-config.json}"
}

config_example_path() {
  printf '%s' "${HAT_AGENT_CONFIG_EXAMPLE:-$SCRIPT_ROOT/agent-tracker/agent-config.example.json}"
}

config_lock_dir() {
  printf '%s' "$(dirname "$(config_path)")/.config.lock.d"
}

_lock_mtime() {
  # Epoch seconds of a path's mtime, digits only. GNU stat first (-c is cleanly
  # rejected by BSD stat, so the fallback fires); BSD stat second (macOS system
  # /usr/bin/stat). Note -f can NOT lead: GNU stat treats -f as "filesystem
  # status" and SUCCEEDS with wrong output, defeating an exit-code fallback.
  local m
  m="$(stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null)"
  printf '%s' "${m//[!0-9]/}"
}

_lock_is_stale() {
  local dir="$1" mtime now
  mtime="$(_lock_mtime "$dir")"
  [ -n "$mtime" ] || return 1
  now="$(date +%s)"
  [ "$((now - mtime))" -gt "$CONFIG_LOCK_STALE" ]
}

config_acquire_lock() {
  local dir; dir="$(config_lock_dir)"
  mkdir -p "$(dirname "$dir")" 2>/dev/null
  while true; do
    if mkdir "$dir" 2>/dev/null; then
      return 0
    fi
    # mkdir failed but the lock dir does NOT exist ⇒ not an existence race
    # (parent unwritable / read-only FS / EACCES). Fail fast, do NOT spin —
    # mirrors the Go reference's `else if !os.IsExist(err) { return nil, err }`.
    if [ ! -d "$dir" ]; then
      say "$(msg config_lock_fail)$dir"
      return 1
    fi
    if _lock_is_stale "$dir"; then
      rm -rf "$dir" 2>/dev/null   # preempt an abandoned lock (holder crashed)
      continue
    fi
    sleep 0.03
  done
}

config_release_lock() {
  rmdir "$(config_lock_dir)" 2>/dev/null || rm -rf "$(config_lock_dir)" 2>/dev/null || true
}

# config_set_field <key> <string-value>
# Under the cross-process lock: seed from the example on first run (design C0),
# jq-merge the new field PRESERVING unknown keys, write to a temp in the same
# dir, then atomic mv. Returns nonzero (without writing) if jq is unavailable.
config_set_field() {
  local field="$1" value="$2" path tmp
  path="$(config_path)"

  if ! command -v jq >/dev/null 2>&1; then
    return 1
  fi

  config_acquire_lock || return 1

  if [ ! -f "$path" ]; then
    mkdir -p "$(dirname "$path")"
    if [ -f "$(config_example_path)" ]; then
      cp "$(config_example_path)" "$path"
    else
      printf '{}\n' > "$path"
    fi
  fi

  tmp="$path.tmp.$$"
  if jq --arg k "$field" --arg v "$value" '.[$k] = $v' "$path" > "$tmp" 2>/dev/null; then
    mv -f "$tmp" "$path"
    config_release_lock
    return 0
  fi
  rm -f "$tmp"
  config_release_lock
  return 1
}

# config_set_field_json <key> <raw-json-value>
# Same lock/seed/atomic-mv protocol as config_set_field, but the value is a raw
# JSON literal (object/array/etc) via --argjson — not a string. Used to persist
# statusline_chain (an object) into agent-config.json.
config_set_field_json() {
  local field="$1" value="$2" path tmp
  path="$(config_path)"

  if ! command -v jq >/dev/null 2>&1; then
    return 1
  fi

  config_acquire_lock || return 1

  if [ ! -f "$path" ]; then
    mkdir -p "$(dirname "$path")"
    if [ -f "$(config_example_path)" ]; then
      cp "$(config_example_path)" "$path"
    else
      printf '{}\n' > "$path"
    fi
  fi

  tmp="$path.tmp.$$"
  if jq --arg k "$field" --argjson v "$value" '.[$k] = $v' "$path" > "$tmp" 2>/dev/null; then
    mv -f "$tmp" "$path"
    config_release_lock
    return 0
  fi
  rm -f "$tmp"
  config_release_lock
  return 1
}

