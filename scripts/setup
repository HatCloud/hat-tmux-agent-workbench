#!/bin/bash
#
# hat-config setup wizard — interactive + non-interactive/CLI installer front-end.
#
# BASH 3.2 COMPATIBLE (macOS system /bin/bash). Do NOT use bash 4+ syntax:
#   no `declare -A`, no `${var,,}`, no `readarray`/`mapfile`, no `${!arr[@]}`
#   name-ref. i18n uses prefix-variable families + indirect expansion `${!v}`.
#
# The front-end parses flags, resolves the decision table, runs the dependency /
# icon / keymap / statusline modules, and finally assembles + invokes
# deploy.sh install with the chosen --skip-* flags (or prints them under
# --dry-run). Intrusive actions default to skip in non-interactive mode.
#
# Subcommands:
#   (default)      run the wizard (interactive) / resolve+emit (non-interactive)
#   agent-guide    emit a static machine-readable JSON contract for agents

set -uo pipefail

# ---------------------------------------------------------------------------
# i18n — MSG_<lang>_<key> prefix families + msg() indirect expansion.
# Add a key: define BOTH MSG_zh_<key> and MSG_en_<key>.
# ---------------------------------------------------------------------------
